# Environment Variables
# Copy this file to .env.local and fill in the actual values.

# The public URL of your website (Used for Sitemap and SEO)
NEXT_PUBLIC_SITE_URL=https://summitdentalcare.com

# Email Configuration (Required for Contact Form to work)
# We recommend using SendGrid, Resend, or Postmark.
# If you do not have an API key, the form will log to console.
EMAIL_SERVICE_API_KEY=your_email_service_api_key_here
EMAIL_FROM_ADDRESS=noreply@summitdentalcare.com
EMAIL_TO_ADDRESS=info@summitdentalcare.com

# Google Analytics 4 (Optional)
# Create a property in GA4 and paste the Measurement ID here.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX